{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "PlatformIO",
      "task": "Build",
      "problemMatcher": [
        "$platformio"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "PlatformIO: Build"
    },
    {
      "type": "PlatformIO", 
      "task": "Upload",
      "problemMatcher": [
        "$platformio"
      ],
      "group": "build",
      "label": "PlatformIO: Upload"
    },
    {
      "type": "PlatformIO",
      "task": "Test",
      "problemMatcher": [
        "$platformio"
      ],
      "group": "test",
      "label": "PlatformIO: Test"
    },
    {
      "type": "shell",
      "command": "pio",
      "args": ["run", "-e", "esp32dev"],
      "group": "build",
      "label": "Build ESP32",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },
    {
      "type": "shell",
      "command": "pio", 
      "args": ["run", "-e", "esp8266"],
      "group": "build",
      "label": "Build ESP8266",
      "presentation": {
        "echo": true,
        "reveal": "always", 
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },
    {
      "type": "shell",
      "command": "pio",
      "args": ["run", "-e", "pico"],
      "group": "build", 
      "label": "Build Pico",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    }
  ]
}